{
    "name": "storybook-solidjs-vite",
    "version": "10.5.1",
    "description": "SolidJS integration with Storybook",
    "private": false,
    "keywords": [
        "storybook",
        "solidjs",
        "solid",
        "storybook-addon",
        "storybook-integration",
        "component-library",
        "ui-components",
        "vite",
        "solid-vite",
        "solid-storybook",
        "frontend",
        "javascript",
        "typescript"
    ],
    "packageManager": "bun@1.3.10",
    "homepage": "https://github.com/solidjs-community/storybook",
    "bugs": {
        "url": "https://github.com/solidjs-community/storybook/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/solidjs-community/storybook.git"
    },
    "license": "MIT",
    "type": "module",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.ts",
            "node": "./dist/node.js",
            "import": "./dist/index.js",
            "code": "./src/index.ts",
            "default": "./dist/index.js"
        },
        "./preset": {
            "types": "./dist/framework/preset.d.ts",
            "code": "./src/framework/preset.ts",
            "default": "./dist/framework/preset.js"
        },
        "./next": {
            "types": "./dist/index.d.ts",
            "code": "./src/index.ts",
            "default": "./dist/index.js"
        },
        "./next/preset": {
            "types": "./dist/framework/preset.d.ts",
            "code": "./src/framework/preset.ts",
            "default": "./dist/framework/preset.js"
        },
        "./experimental-playwright": {
            "types": "./dist/playwright.d.ts",
            "code": "./src/playwright.ts",
            "default": "./dist/playwright.js"
        },
        "./renderer": {
            "types": "./dist/renderer.d.ts",
            "code": "./src/renderer/index.ts",
            "default": "./dist/renderer.js"
        },
        "./renderer/solid": {
            "types": "./dist/renderer/solid.d.ts",
            "code": "./src/renderer/solid.ts",
            "default": "./dist/renderer/solid.js"
        },
        "./renderer/solid-next": {
            "types": "./dist/renderer/solid-next.d.ts",
            "code": "./src/renderer/solid-next.ts",
            "default": "./dist/renderer/solid-next.js"
        },
        "./renderer/docs": {
            "types": "./dist/renderer/docs.d.ts",
            "code": "./src/renderer/docs.ts",
            "default": "./dist/renderer/docs.js"
        }
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "README.md",
        "src/**/*",
        "dist/**/*",
        "**/*.d.ts",
        "template/**/*"
    ],
    "scripts": {
        "prepare": "simple-git-hooks",
        "prepack": "bun run build",
        "build": "tsup",
        "typecheck": "tsc --noEmit",
        "dev": "tsup --watch",
        "test": "vitest run --passWithNoTests",
        "clean": "rm -rf dist && rm -rf node_modules",
        "lint": "eslint . --fix --max-warnings=9999 --quiet",
        "changelog": "changeset",
        "version-packages": "changeset version",
        "release": "changeset publish",
        "release:next": "changeset publish --tag next"
    },
    "dependencies": {
        "@storybook/builder-vite": "10.4.4",
        "@storybook/global": "5.0.0",
        "@volar/language-core": "2.4.28",
        "@volar/typescript": "2.4.28",
        "semver": "7.8.1"
    },
    "devDependencies": {
        "@changesets/cli": "2.31.0",
        "@commitlint/cli": "20.5.3",
        "@commitlint/config-conventional": "20.5.3",
        "@flexbe/eslint-config": "3.0.3",
        "@tsconfig/strictest": "2.0.8",
        "@types/node": "25.9.3",
        "@types/semver": "7.7.1",
        "es-toolkit": "1.47.1",
        "eslint": "9.39.4",
        "lint-staged": "16.4.0",
        "simple-git-hooks": "2.13.1",
        "@solidjs/web": "2.0.0-beta.14",
        "solid-js": "1.9.13",
        "solid-js-next": "npm:solid-js@next",
        "storybook": "10.4.4",
        "tsup": "8.5.1",
        "type-fest": "5.7.0",
        "typescript": "5.9.3",
        "vitest": "4.1.8"
    },
    "peerDependencies": {
        "@solidjs/web": "^2.0.0-0",
        "solid-js": "^1.8.0-0 || ^2.0.0-0",
        "storybook": "^0.0.0-0 || ^10.0.0",
        "vite": "7.1.11",
        "vite-plugin-solid": "2.11.12",
        "typescript": "^4.0.0 || ^5.0.0 || ^6.0.0"
    },
    "peerDependenciesMeta": {
        "@solidjs/web": {
            "optional": true
        },
        "typescript": {
            "optional": true
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "simple-git-hooks": {
        "pre-commit": "bunx --no-install lint-staged",
        "commit-msg": "bunx --no-install commitlint --edit \"$1\""
    },
    "lint-staged": {
        "*.{js,mjs,jsx,ts,tsx}": [
            "eslint --fix --max-warnings=9999 --quiet"
        ]
    },
    "commitlint": {
        "extends": [
            "@commitlint/config-conventional"
        ],
        "rules": {
            "type-enum": [
                2,
                "always",
                [
                    "feat",
                    "fix",
                    "chore",
                    "refactor",
                    "docs",
                    "test",
                    "ci",
                    "perf",
                    "revert"
                ]
            ],
            "type-case": [
                2,
                "always",
                "lower-case"
            ],
            "type-empty": [
                2,
                "never"
            ],
            "subject-empty": [
                2,
                "never"
            ],
            "subject-min-length": [
                1,
                "always",
                4
            ],
            "body-max-line-length": [
                1,
                "always",
                250
            ],
            "subject-case": [
                2,
                "never",
                [
                    "pascal-case",
                    "upper-case"
                ]
            ]
        }
    }
}
